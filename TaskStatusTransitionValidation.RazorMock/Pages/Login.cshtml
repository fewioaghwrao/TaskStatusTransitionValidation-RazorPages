@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

<main class="login-page">
    <div class="login-shell">
        <div class="login-brand">
            <div class="login-badge">
                <span aria-hidden="true" class="login-badge-dot"></span>
                <span>小規模チーム向け 案件・タスク管理</span>
            </div>

            <h1 class="login-title">サインイン</h1>

            <p class="login-description">
                案件とタスクの進捗を一元管理し、チームでの共有をスムーズにします。
            </p>
        </div>

        <section class="login-card">
            <form method="post" id="loginForm" class="login-form">
                <div class="form-group">
                    <label asp-for="Input.Email" class="form-label">メールアドレス</label>

                    <input asp-for="Input.Email"
                           id="email"
                           class="form-input"
                           autocomplete="email"
                           placeholder="you@example.com" />

                    <span asp-validation-for="Input.Email" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password" class="form-label">パスワード</label>

                    <div class="password-wrapper">
                        <input asp-for="Input.Password"
                               id="passwordInput"
                               class="form-input form-input--password"
                               type="password"
                               autocomplete="current-password"
                               placeholder="••••••••" />

                        <button type="button"
                                id="togglePasswordBtn"
                                class="password-toggle-button"
                                aria-label="パスワードを表示">
                            👁
                        </button>
                    </div>

                    <span asp-validation-for="Input.Password" class="form-error"></span>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div role="alert" class="login-alert-error">
                        @Model.ErrorMessage
                    </div>
                }

                <button type="submit"
                        id="submitBtn"
                        class="login-button">
                    ログイン
                </button>

                <div class="login-footer-note">
                    <div>
                        ※ 本システムはデモ環境です。ログイン情報がない場合は管理者へご連絡ください。
                    </div>
                    <div class="login-version">
                        v0.1 demo
                    </div>
                </div>
            </form>
        </section>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const passwordInput = document.getElementById("passwordInput");
            const togglePasswordBtn = document.getElementById("togglePasswordBtn");
            const form = document.getElementById("loginForm");
            const submitBtn = document.getElementById("submitBtn");
            const emailInput = document.getElementById("email");

            function resetSubmitButton() {
                if (!submitBtn) return;
                submitBtn.disabled = false;
                submitBtn.textContent = "ログイン";
                submitBtn.style.cursor = "pointer";
                submitBtn.style.opacity = "1";
            }

            function setSubmittingState() {
                if (!submitBtn) return;
                submitBtn.disabled = true;
                submitBtn.textContent = "ログイン中…";
                submitBtn.style.cursor = "not-allowed";
                submitBtn.style.opacity = "0.85";
            }

            function canSubmitForm() {
                if (!form) return false;

                // HTML5 バリデーション
                if (!form.checkValidity()) {
                    form.reportValidity();
                    return false;
                }

                // jQuery Validate / unobtrusive validation がある場合はその結果も使う
                if (window.jQuery && typeof window.jQuery(form).valid === "function") {
                    return window.jQuery(form).valid();
                }

                return true;
            }

            // 画面表示時は常に通常状態へ戻す
            resetSubmitButton();

            // ブラウザ戻るなどの復元対策
            window.addEventListener("pageshow", function () {
                resetSubmitButton();
            });

            if (togglePasswordBtn && passwordInput) {
                togglePasswordBtn.addEventListener("click", function () {
                    const isPassword = passwordInput.type === "password";
                    passwordInput.type = isPassword ? "text" : "password";
                    togglePasswordBtn.textContent = isPassword ? "🙈" : "👁";
                    togglePasswordBtn.setAttribute(
                        "aria-label",
                        isPassword ? "パスワードを非表示" : "パスワードを表示"
                    );
                });
            }

            if (form) {
                form.addEventListener("submit", function (e) {
                    // すでに送信中なら二重送信を防ぐ
                    if (submitBtn && submitBtn.disabled) {
                        e.preventDefault();
                        return;
                    }

                    // バリデーションNGなら送信状態にしない
                    if (!canSubmitForm()) {
                        resetSubmitButton();
                        e.preventDefault();
                        return;
                    }

                    // バリデーションOKのときだけ送信中表示
                    setSubmittingState();
                });
            }

            if (emailInput && form) {
                emailInput.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        form.requestSubmit();
                    }
                });
            }

            if (passwordInput && form) {
                passwordInput.addEventListener("keydown", function (e) {
                    if (e.key === "Enter") {
                        e.preventDefault();
                        form.requestSubmit();
                    }
                });
            }
        })();
    </script>
}